# DataForge Environment Docker image
# Serves the OpenEnv-compatible RL environment

FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    mv /root/.local/bin/uv /usr/local/bin/uv && \
    mv /root/.local/bin/uvx /usr/local/bin/uvx

WORKDIR /app

COPY pyproject.toml uv.lock ./
COPY dataforge/ dataforge/
COPY fixtures/ fixtures/
COPY constitutions/ constitutions/

RUN uv sync --frozen --no-editable --extra playground

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app:$PYTHONPATH"

EXPOSE 7860

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:7860/health || exit 1

CMD ["uvicorn", "dataforge.env.server:app", "--host", "0.0.0.0", "--port", "7860"]
